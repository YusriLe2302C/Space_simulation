# Backend REST API base URL (no trailing slash)
VITE_API_URL=http://localhost:3000

# Backend WebSocket URL (same server as API in this setup)
VITE_SOCKET_URL=http://localhost:3000

# Set to "true" to enable React StrictMode (causes double effect invocation in dev)
# Leave false unless you are specifically testing strict-mode behaviour
VITE_STRICT_MODE=false
